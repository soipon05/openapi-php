                $body .= "Content-Disposition: form-data; name=\"{$safeName}\"; filename=\"{$safeName}\"\r\n";
                $body .= "Content-Type: application/octet-stream\r\n\r\n";
                $body .= (string) $value;
            } else {
                $body .= "Content-Disposition: form-data; name=\"{$safeName}\"\r\n\r\n";
                $body .= (string) $value;
